# Copy to packages/backend/.env (or repo root) and fill values.
# See README.md for provider examples (OpenAI, Groq, OpenRouter).

# --- AI ---
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# true = offline template worlds (no API key required)
DEMO_MODE=false

# --- Server ---
PORT=3001
DB_PATH=./data/worlds.db
# production | development | test
NODE_ENV=development

# --- Open-world scale (optional) ---
# compact | standard | expansive | epic | custom
# XMV_WORLD_SCALE=standard
# Fine-tune (custom / override any scale):
# XMV_LOCATIONS_MAX=16
# XMV_LOCATIONS_TARGET=12
# XMV_QUESTS_MAX=8

# --- Feature modules (optional) ---
# Disable: XMV_FEATURES_DISABLED=journal,relationships,marketplace
# Features: world,travel,roleplay,player,quest,rpg,save,auth,multiplayer,marketplace,streaming

# --- Security / ops (optional) ---
# CORS_ORIGIN=http://localhost:5173
# TRUST_PROXY=true
# JSON_BODY_LIMIT=256kb
# RATE_LIMIT_MAX=180
# RATE_LIMIT_WINDOW_MS=60000

# --- CLI ---
# XMV_API_URL=http://localhost:3001
